services:
  nginx-router:
    image: nginx:alpine
    container_name: {{project_name}}-feature-router
    # Linux: use host networking so nginx can reach localhost ports
    # macOS: use ports mapping instead (change to: ports: ["80:80"])
    network_mode: host
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./conf.d:/etc/nginx/conf.d:ro
    restart: unless-stopped
