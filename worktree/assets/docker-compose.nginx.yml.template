services:
  nginx-router:
    image: nginx:alpine
    container_name: {{project_name}}-feature-router
    ports:
      - "{{nginx_port}}:{{nginx_port}}"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./conf.d:/etc/nginx/conf.d:ro
    restart: unless-stopped
