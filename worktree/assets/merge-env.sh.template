#!/usr/bin/env bash
# =============================================================================
# merge-env.sh — Merge main .env + worktree .env.overrides → worktree .env
# Generated by: /worktree bootstrap
#
# Copies the main checkout's .env (with secrets) into the worktree,
# then applies .env.overrides on top. Run at START time, not create time.
#
# The agent should NEVER read .env — only .env.overrides and .env.sample.
#
# Usage: merge-env.sh <slot>
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

SLOT="${1:?Usage: merge-env.sh <slot>}"
SLOT_DIR="$ROOT_DIR/.worktrees/slot-${SLOT}"

[[ -d "$SLOT_DIR" ]] || { echo "[!] Slot directory not found: $SLOT_DIR" >&2; exit 1; }

# Apply overrides from .env.overrides onto a .env file.
apply_overrides() {
    local env_file="$1" overrides_file="$2"
    [[ -f "$overrides_file" ]] || return 0

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$line" ]] && continue

        local key="${line%%=*}"
        local value="${line#*=}"

        if grep -q "^${key}=" "$env_file" 2>/dev/null; then
            awk -v k="$key" -v v="$value" 'BEGIN{FS="="} $1==k{print k"="v; next}1' \
                "$env_file" > "${env_file}.tmp" && mv "${env_file}.tmp" "$env_file"
        else
            echo "${key}=${value}" >> "$env_file"
        fi
    done < "$overrides_file"
}

# Copy main .env to worktree, then apply overrides
merge_service() {
    local svc_name="$1" main_dir="$2" worktree_dir="$3" sample_name="${4:-.env.sample}"
    [[ -d "$worktree_dir" ]] || return 0

    local overrides="$worktree_dir/.env.overrides"
    [[ -f "$overrides" ]] || { echo "  [!] No .env.overrides for $svc_name — skipping"; return 0; }

    if [[ -f "$main_dir/.env" ]]; then
        cp "$main_dir/.env" "$worktree_dir/.env"
    elif [[ -f "$main_dir/$sample_name" ]]; then
        cp "$main_dir/$sample_name" "$worktree_dir/.env"
        echo "  [!] $svc_name: using $sample_name (secrets will be empty)"
    else
        touch "$worktree_dir/.env"
    fi

    apply_overrides "$worktree_dir/.env" "$overrides"
    echo "  [env] Merged $svc_name/.env"
}

# =============================================
# REPLACE: one merge_service call per service
#
# merge_service "<name>" "$ROOT_DIR/<main_path>" "$SLOT_DIR/<repo_key>/<subdir>" "<sample_name>"
# =============================================

# =============================================
# Copy private files (credentials, keys, certs)
# REPLACE: list files from worktree.yml private_files section
# These are gitignored files that services need to run.
# =============================================
copy_private_file() {
    local src="$ROOT_DIR/$1" dst="$SLOT_DIR/$1"
    if [[ -f "$src" ]]; then
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst"
    fi
}

# REPLACE: one copy_private_file call per entry in worktree.yml private_files
# Example:
# copy_private_file "be/firebase-service-account.json"
# copy_private_file "genai/service-account.json"

echo "  [OK] Environment files merged for slot ${SLOT}"
