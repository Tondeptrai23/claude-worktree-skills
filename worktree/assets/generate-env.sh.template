#!/usr/bin/env bash
# =============================================================================
# generate-env.sh — Generate .env.overrides for feature worktrees
# Generated by: /worktree bootstrap
#
# Only writes port/URL overrides. NEVER copies secrets.
# The actual .env files are produced by merge-env.sh at start time.
#
# Usage: generate-env.sh <slot>
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

SLOT="${1:?Usage: generate-env.sh <slot>}"
SLOT_DIR="$ROOT_DIR/.worktrees/slot-${SLOT}"

[[ -d "$SLOT_DIR" ]] || { echo "[!] Slot directory not found: $SLOT_DIR" >&2; exit 1; }

# =============================================
# GENERATED CONFIG — REPLACE per project
# =============================================
PORT_OFFSET=100

# =============================================
# Per-service .env.overrides generation
#
# Claude: for each service in worktree.yml, write a block like:
#
#   if [[ -d "$SLOT_DIR/<repo_key>" ]]; then
#       cat > "$SLOT_DIR/<repo_key>/<subdir>/.env.overrides" <<EOF
#   # Worktree slot ${SLOT} overrides
#   PORT=$(( <port_base> + SLOT * PORT_OFFSET ))
#   VITE_API_URL=http://f${SLOT}-api.localhost
#   ...only port/URL overrides, NO secrets...
#   EOF
#   fi
#
# Template resolution:
#   {{self.port}}  → $(( port_base + SLOT * PORT_OFFSET ))
#   {{svc.port}}   → $(( other_port_base + SLOT * PORT_OFFSET ))
#   {{svc.url}}    → nginx subdomain URL (for browser vars) or localhost:port (for server vars)
#   {{db.host}}, {{db.port}}, {{db.name}}, {{db.user}}, {{db.password}}, {{db.schema}} → DB connection vars
# =============================================

echo "  [OK] Override files generated for slot ${SLOT}"
