#!/usr/bin/env bash
# =============================================================================
# nginx-gen.sh — Generate nginx configs for active feature worktree slots
# Generated by: /worktree bootstrap
# Usage: nginx-gen.sh
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONF_DIR="$ROOT_DIR/nginx/conf.d"

mkdir -p "$CONF_DIR"
rm -f "$CONF_DIR"/slot-*.conf

# =============================================
# GENERATED CONFIG — customize per project
# Replace this entire block with actual values during bootstrap.
# =============================================
PORT_OFFSET=100  # REPLACE with value from worktree.yml

# Service definitions for nginx: name|port_base|subdomain_pattern|repo_key
# subdomain_pattern uses {N} for slot number
NGINX_SERVICES=(
    # REPLACE: one entry per exposed service, e.g.:
    # "fe-app|5173|f{N}.localhost|fe"
    # "be|8080|f{N}-api.localhost|be"
)
# =============================================

parse_field() {
    echo "$1" | cut -d'|' -f"$2"
}

generated=0

for slot_dir in "$ROOT_DIR"/.worktrees/slot-*/; do
    [[ -d "$slot_dir" ]] || continue
    [[ -f "$slot_dir/.slot-meta" ]] || continue
    source "$slot_dir/.slot-meta"

    N="$SLOT"
    conf_file="$CONF_DIR/slot-${N}.conf"

    echo "# Feature slot ${N}: ${FEATURE_NAME}" > "$conf_file"
    echo "# Generated: $(date -Iseconds)" >> "$conf_file"
    echo "" >> "$conf_file"

    for svc_def in "${NGINX_SERVICES[@]}"; do
        svc_name=$(parse_field "$svc_def" 1)
        svc_port_base=$(parse_field "$svc_def" 2)
        svc_subdomain_tpl=$(parse_field "$svc_def" 3)
        svc_repo_key=$(parse_field "$svc_def" 4)

        [[ -d "$slot_dir/$svc_repo_key" ]] || continue

        svc_port=$(( svc_port_base + N * PORT_OFFSET ))
        svc_subdomain="${svc_subdomain_tpl//\{N\}/$N}"

        cat >> "$conf_file" <<NGINX
# $svc_name
server {
    listen 80;
    server_name ${svc_subdomain};

    client_max_body_size 100M;

    location / {
        proxy_pass http://localhost:${svc_port};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_read_timeout 300s;
    }
}

NGINX
    done

    echo "[OK] Generated $conf_file"
    generated=$((generated + 1))
done

if [[ $generated -eq 0 ]]; then
    echo "[*] No active slots — nginx conf.d/ cleared"
else
    echo "[OK] Generated configs for $generated slot(s)"
fi
