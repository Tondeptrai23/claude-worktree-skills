#!/usr/bin/env bash
# =============================================================================
# feature-worktree.sh — Multi-feature worktree lifecycle management
# Generated by: /worktree bootstrap
#
# Requires: bash 4.2+ (for associative arrays and [[ -v ]])
#
# Commands:
#   create <slot> <name> [--services svc1,svc2] [--<svc>-branch X ...]
#   start  <slot> [--services svc1,svc2] [--mode dev|docker]
#   stop   <slot>
#   destroy <slot> [--drop-schema]
#   status [slot]
#   logs   <slot> [service]
# =============================================================================
set -euo pipefail

# Bash version check
if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 2) )); then
    echo "[!] Requires bash 4.2+. Current: $BASH_VERSION" >&2
    echo "    macOS users: brew install bash" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKTREES_DIR="$ROOT_DIR/.worktrees"

# =============================================
# GENERATED CONFIG — customize per project
# =============================================
MAX_SLOTS={{max_slots}}
PORT_OFFSET={{port_offset}}
GIT_TOPOLOGY={{git_topology}}  # monorepo | multi-repo
DEFAULT_MODE={{default_mode}}  # dev | docker

# Service definitions: name|path|subdir|port_base|port_env|dev_start|dev_install
# Each service is a line in this array.
# Customize this block during bootstrap.
SERVICES=(
{{#each services}}
    "{{key}}|{{path}}|{{subdir}}|{{port_base}}|{{port_env}}|{{dev_start}}|{{dev_install}}"
{{/each}}
)

# =============================================
# END GENERATED CONFIG
# =============================================

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log_info()  { echo -e "${GREEN}[*]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
log_error() { echo -e "${RED}[!]${NC} $*" >&2; }
log_ok()    { echo -e "${GREEN}[OK]${NC} $*"; }

# Port calculation
slot_port() { echo $(( $1 + $2 * PORT_OFFSET )); }

# Check if a value is in a comma-separated list (exact match, not substring)
in_csv() {
    local needle="$1" haystack="$2"
    IFS=',' read -ra items <<< "$haystack"
    for item in "${items[@]}"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

# Parse service definition string
svc_field() {
    local def="$1" field="$2"
    echo "$def" | cut -d'|' -f"$field"
}
svc_name()      { svc_field "$1" 1; }
svc_path()      { svc_field "$1" 2; }
svc_subdir()    { svc_field "$1" 3; }
svc_port_base() { svc_field "$1" 4; }
svc_port_env()  { svc_field "$1" 5; }
svc_dev_start() { svc_field "$1" 6; }
svc_dev_install() { svc_field "$1" 7; }

# Get service def by name
get_svc() {
    local target="$1"
    for def in "${SERVICES[@]}"; do
        if [[ "$(svc_name "$def")" == "$target" ]]; then
            echo "$def"
            return 0
        fi
    done
    return 1
}

# Get the repo directory for a service (handles multi-repo vs monorepo)
svc_repo_dir() {
    local path
    path=$(svc_path "$1")
    echo "$ROOT_DIR/$path"
}

# Get the worktree target directory for a service in a slot
svc_worktree_dir() {
    local name path subdir slot="$2"
    name=$(svc_name "$1")
    path=$(svc_path "$1")
    subdir=$(svc_subdir "$1")
    # For services sharing a repo (e.g., fe/app, fe/admin), the worktree is the repo
    # The subdir is just where to cd for running commands
    echo "$WORKTREES_DIR/slot-${slot}/${path##*/}"
}

# Get the working directory for running commands (repo + subdir)
svc_work_dir() {
    local wt_dir subdir
    wt_dir=$(svc_worktree_dir "$1" "$2")
    subdir=$(svc_subdir "$1")
    if [[ -n "$subdir" ]]; then
        echo "$wt_dir/$subdir"
    else
        echo "$wt_dir"
    fi
}

# =============================================================================
# CREATE
# =============================================================================
cmd_create() {
    local slot="" name="" filter_services=""
    slot="${1:?Usage: feature-worktree.sh create <slot> <name> [--services svc1,svc2] [--<svc>-branch X ...]}"
    name="${2:?Usage: feature-worktree.sh create <slot> <name> ...}"
    shift 2

    # Parse flags
    declare -A branches
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --services)
                filter_services="$2"; shift 2 ;;
            --*-branch)
                local svc_name="${1#--}"
                svc_name="${svc_name%-branch}"
                branches["$svc_name"]="$2"
                shift 2
                ;;
            *) log_error "Unknown option: $1"; exit 1 ;;
        esac
    done

    # Validate slot
    if [[ ! "$slot" =~ ^[1-9]$ ]] || (( slot > MAX_SLOTS )); then
        log_error "Slot must be 1-${MAX_SLOTS}, got: $slot"
        exit 1
    fi

    local slot_dir="$WORKTREES_DIR/slot-${slot}"
    if [[ -d "$slot_dir" ]]; then
        log_error "Slot $slot already in use. Run 'destroy $slot' first."
        exit 1
    fi

    # Determine which services to create:
    # 1. If --services specified, only set branches for those
    # 2. Else if any --*-branch specified, use only those
    # 3. Else default to all
    if [[ -n "$filter_services" ]]; then
        IFS=',' read -ra svc_list <<< "$filter_services"
        for def in "${SERVICES[@]}"; do
            local sn
            sn=$(svc_name "$def")
            if in_csv "$sn" "$filter_services" && [[ ! -v "branches[$sn]" ]]; then
                branches["$sn"]="feature/$name"
            fi
        done
    elif [[ ${#branches[@]} -eq 0 ]]; then
        for def in "${SERVICES[@]}"; do
            local sn
            sn=$(svc_name "$def")
            branches["$sn"]="feature/$name"
        done
    fi

    # Check disk space
    local free_kb
    free_kb=$(df --output=avail "$ROOT_DIR" 2>/dev/null | tail -1 | tr -d ' ')
    if (( free_kb < 5242880 )); then
        log_warn "Low disk space: $(( free_kb / 1048576 ))GB free"
    fi

    log_info "Creating feature slot $slot: '$name'"
    mkdir -p "$slot_dir"

    # Track which repos already have a worktree created (for shared repos like fe/)
    declare -A created_repos
    local services_created=""

    for def in "${SERVICES[@]}"; do
        local sn sp
        sn=$(svc_name "$def")
        sp=$(svc_path "$def")

        # Skip if no branch specified for this service
        [[ -v "branches[$sn]" ]] || continue
        local branch="${branches[$sn]}"

        local repo_dir="$ROOT_DIR/$sp"
        local repo_key="${sp##*/}"  # normalize: ./fe -> fe

        # Skip if we already created a worktree for this repo (shared repo case)
        if [[ -v "created_repos[$repo_key]" ]]; then
            services_created="${services_created}${sn},"
            continue
        fi

        if [[ ! -d "$repo_dir/.git" && ! -f "$repo_dir/.git" ]]; then
            log_warn "Skipping $sn: no git repo at $repo_dir"
            continue
        fi

        local wt_target="$WORKTREES_DIR/slot-${slot}/$repo_key"
        log_info "Creating $repo_key/ worktree on branch '$branch'"

        if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
            git -C "$repo_dir" worktree add "$wt_target" "$branch"
        elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
            git -C "$repo_dir" worktree add --track -b "$branch" "$wt_target" "origin/$branch"
        else
            git -C "$repo_dir" worktree add -b "$branch" "$wt_target"
        fi

        created_repos["$repo_key"]=1
        services_created="${services_created}${sn},"
    done

    if [[ -z "$services_created" ]]; then
        log_error "No worktrees created."
        rmdir "$slot_dir" 2>/dev/null || true
        exit 1
    fi

    # Write metadata
    {
        echo "SLOT=$slot"
        echo "FEATURE_NAME=$name"
        echo "CREATED_AT=$(date -Iseconds)"
        for def in "${SERVICES[@]}"; do
            local sn
            sn=$(svc_name "$def")
            local uc_name
            uc_name=$(echo "$sn" | tr '[:lower:]-' '[:upper:]_')
            echo "${uc_name}_BRANCH=${branches[$sn]:-}"
            echo "${uc_name}_PORT=$(slot_port "$(svc_port_base "$def")" "$slot")"
        done
    } > "$slot_dir/.slot-meta"

    # Generate env files
    log_info "Generating environment files"
    "$SCRIPT_DIR/generate-env.sh" "$slot"

    # Create DB schema if configured (only if backend services are in the slot)
    # REPLACE: customize the directory check based on which services use the database
    # REPLACE: customize psql command based on database.isolation in worktree.yml
    local has_db_service=false
    for def in "${SERVICES[@]}"; do
        local sn sp
        sn=$(svc_name "$def")
        sp=$(svc_path "$def")
        local repo_key="${sp##*/}"
        [[ -d "$slot_dir/$repo_key" ]] || continue
        # REPLACE: list service names that use the database
        [[ "$sn" == "api" || "$sn" == "worker" ]] && has_db_service=true
    done
    if [[ "$has_db_service" == "true" ]]; then
        log_info "Creating database schema: feature_${slot}"
        # REPLACE: customize host, user, db name from worktree.yml
        psql -h localhost -U postgres -d mydb \
            -c "CREATE SCHEMA IF NOT EXISTS feature_${slot};" 2>/dev/null || \
            log_warn "Could not create DB schema. Run 'make infra' first if you need backend services."
    fi

    # Install dependencies
    declare -A installed_repos
    for def in "${SERVICES[@]}"; do
        local sn sp install_cmd
        sn=$(svc_name "$def")
        sp=$(svc_path "$def")
        install_cmd=$(svc_dev_install "$def")
        local repo_key="${sp##*/}"

        [[ "$services_created" == *"${sn},"* ]] || continue
        [[ -n "$install_cmd" && "$install_cmd" != "null" ]] || continue
        [[ ! -v "installed_repos[$repo_key]" ]] || continue

        local work_dir
        work_dir=$(svc_work_dir "$def" "$slot")
        log_info "Installing dependencies for $sn"
        (cd "$work_dir" && eval "$install_cmd" 2>&1 | tail -5) || log_warn "Install failed for $sn"
        installed_repos["$repo_key"]=1
    done

    # Regenerate nginx
    "$SCRIPT_DIR/nginx-gen.sh"
    if docker ps --format '{{{{.Names}}}}' 2>/dev/null | grep -q 'feature-router'; then
        docker exec "$(docker ps --format '{{{{.Names}}}}' | grep feature-router)" nginx -s reload 2>/dev/null || true
    fi

    echo ""
    log_ok "Feature slot $slot created: '$name'"
    echo "  Services: ${services_created%,}"
    echo "  Path: $slot_dir"
    echo "  Start: make feature-start SLOT=$slot"
}

# =============================================================================
# START
# =============================================================================
cmd_start() {
    local slot="${1:?Usage: feature-worktree.sh start <slot>}"
    shift
    local filter_services="" mode="$DEFAULT_MODE"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --services) filter_services="$2"; shift 2 ;;
            --mode) mode="$2"; shift 2 ;;
            *) log_error "Unknown option: $1"; exit 1 ;;
        esac
    done

    local slot_dir="$WORKTREES_DIR/slot-${slot}"
    [[ -d "$slot_dir" ]] || { log_error "Slot $slot does not exist"; exit 1; }

    # Ensure nginx is running
    # REPLACE: customize container name and compose file path for your project
    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q 'feature-router'; then
        log_info "Starting nginx feature router"
        "$SCRIPT_DIR/nginx-gen.sh"
        docker compose -f "$DEV_ENV_DIR/nginx/docker-compose.nginx.yml" up -d 2>/dev/null && \
            log_ok "Nginx running on port 80" || \
            log_warn "Could not start nginx (port 80 may be in use)"
    fi

    mkdir -p "$slot_dir/.pids" "$slot_dir/.logs"

    for def in "${SERVICES[@]}"; do
        local sn sp subdir port
        sn=$(svc_name "$def")
        sp=$(svc_path "$def")

        # Filter by requested services (exact match, not substring)
        if [[ -n "$filter_services" ]] && ! in_csv "$sn" "$filter_services"; then
            continue
        fi

        local work_dir
        work_dir=$(svc_work_dir "$def" "$slot")
        [[ -d "$work_dir" ]] || continue

        port=$(slot_port "$(svc_port_base "$def")" "$slot")
        local pid_file="$slot_dir/.pids/${sn}.pid"

        if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
            log_warn "$sn already running (PID $(cat "$pid_file"))"
            continue
        fi

        local start_cmd
        start_cmd=$(svc_dev_start "$def")
        # Resolve {{self.port}} in start command
        start_cmd="${start_cmd//\{\{self.port\}\}/$port}"

        local port_env
        port_env=$(svc_port_env "$def")

        log_info "Starting $sn on port $port"
        # Use setsid to create a new process group, so we can kill
        # the entire tree later (important for Gradle/JVM which fork).
        (
            cd "$work_dir"
            if [[ -n "$port_env" && "$port_env" != "null" ]]; then
                export "$port_env"="$port"
            fi
            setsid bash -c "$start_cmd" > "$slot_dir/.logs/${sn}.log" 2>&1 &
            echo $! > "$pid_file"
        )
        log_ok "$sn started (PID $(cat "$pid_file"))"
    done

    echo ""
    log_ok "Services started for slot $slot"
    echo "  Logs: $slot_dir/.logs/"
    echo "  Stop: make feature-stop SLOT=$slot"
}

# =============================================================================
# STOP
# =============================================================================
cmd_stop() {
    local slot="${1:?Usage: feature-worktree.sh stop <slot>}"
    local slot_dir="$WORKTREES_DIR/slot-${slot}"
    [[ -d "$slot_dir" ]] || { log_error "Slot $slot does not exist"; exit 1; }

    local pids_dir="$slot_dir/.pids"
    [[ -d "$pids_dir" ]] || { log_warn "No PID files for slot $slot"; return 0; }

    log_info "Stopping services for slot $slot"
    for pid_file in "$pids_dir"/*.pid; do
        [[ -f "$pid_file" ]] || continue
        local sn pid
        sn=$(basename "$pid_file" .pid)
        pid=$(cat "$pid_file")

        if kill -0 "$pid" 2>/dev/null; then
            kill -- -"$(ps -o pgid= -p "$pid" | tr -d ' ')" 2>/dev/null || \
            kill "$pid" 2>/dev/null || true
            log_ok "Stopped $sn (PID $pid)"
        else
            log_warn "$sn (PID $pid) was not running"
        fi
        rm -f "$pid_file"
    done
    log_ok "All services stopped for slot $slot"
}

# =============================================================================
# DESTROY
# =============================================================================
cmd_destroy() {
    local slot="${1:?Usage: feature-worktree.sh destroy <slot> [--drop-schema]}"
    shift
    local drop_schema=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --drop-schema) drop_schema=true; shift ;;
            *) log_error "Unknown option: $1"; exit 1 ;;
        esac
    done

    local slot_dir="$WORKTREES_DIR/slot-${slot}"
    [[ -d "$slot_dir" ]] || { log_error "Slot $slot does not exist"; exit 1; }

    cmd_stop "$slot" 2>/dev/null || true
    log_info "Destroying feature slot $slot"

    # Remove worktrees
    declare -A removed_repos
    for def in "${SERVICES[@]}"; do
        local sp repo_key
        sp=$(svc_path "$def")
        repo_key="${sp##*/}"
        [[ ! -v "removed_repos[$repo_key]" ]] || continue
        if [[ -d "$slot_dir/$repo_key" ]]; then
            log_info "Removing $repo_key/ worktree"
            git -C "$ROOT_DIR/$sp" worktree remove "$slot_dir/$repo_key" --force 2>/dev/null || \
                rm -rf "$slot_dir/$repo_key"
            removed_repos["$repo_key"]=1
        fi
    done

    {{#if database_isolation_schema}}
    if [[ "$drop_schema" == "true" ]]; then
        log_info "Dropping database schema: feature_${slot}"
        psql -h {{db_host}} -U {{db_user}} -d {{db_name}} \
            -c "DROP SCHEMA IF EXISTS feature_${slot} CASCADE;" 2>/dev/null || \
            log_warn "Could not drop schema"
    fi
    {{/if}}

    rm -rf "$slot_dir"
    "$SCRIPT_DIR/nginx-gen.sh"

    if docker ps --format '{{{{.Names}}}}' 2>/dev/null | grep -q 'feature-router'; then
        docker exec "$(docker ps --format '{{{{.Names}}}}' | grep feature-router)" nginx -s reload 2>/dev/null || true
    fi

    log_ok "Feature slot $slot destroyed"
}

# =============================================================================
# STATUS
# =============================================================================
cmd_status() {
    local filter_slot="${1:-}"
    echo ""
    echo "=== Feature Worktree Status ==="
    echo ""

    local found=false
    for slot_dir in "$WORKTREES_DIR"/slot-*/; do
        [[ -d "$slot_dir" ]] || continue
        [[ -f "$slot_dir/.slot-meta" ]] || continue
        source "$slot_dir/.slot-meta"
        [[ -z "$filter_slot" || "$SLOT" == "$filter_slot" ]] || continue
        found=true

        echo -e "${CYAN}Slot $SLOT: $FEATURE_NAME${NC}"
        echo "  Created: $CREATED_AT"
        echo "  Path:    $slot_dir"

        for def in "${SERVICES[@]}"; do
            local sn sp port
            sn=$(svc_name "$def")
            sp=$(svc_path "$def")
            local repo_key="${sp##*/}"
            [[ -d "$slot_dir/$repo_key" ]] || continue

            port=$(slot_port "$(svc_port_base "$def")" "$SLOT")
            local status="${RED}stopped${NC}"
            local pid_file="$slot_dir/.pids/${sn}.pid"
            if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
                status="${GREEN}running${NC} (PID $(cat "$pid_file"))"
            fi
            printf "  %-20s port %-5s %b\n" "$sn" "$port" "$status"
        done
        echo ""
    done

    if [[ "$found" == "false" ]]; then
        echo "  No active feature slots."
        echo "  Create one: make feature-create SLOT=1 NAME=my-feature"
        echo ""
    fi
}

# =============================================================================
# LOGS
# =============================================================================
cmd_logs() {
    local slot="${1:?Usage: feature-worktree.sh logs <slot> [service]}"
    local service="${2:-}"
    local logs_dir="$WORKTREES_DIR/slot-${slot}/.logs"
    [[ -d "$logs_dir" ]] || { log_error "No logs for slot $slot"; exit 1; }

    if [[ -n "$service" ]]; then
        [[ -f "$logs_dir/${service}.log" ]] || { log_error "No log: $service"; exit 1; }
        tail -f "$logs_dir/${service}.log"
    else
        tail -f "$logs_dir"/*.log
    fi
}

# =============================================================================
# DISPATCH
# =============================================================================
cmd="${1:-help}"; shift || true
case "$cmd" in
    create)  cmd_create "$@" ;;
    start)   cmd_start "$@" ;;
    stop)    cmd_stop "$@" ;;
    destroy) cmd_destroy "$@" ;;
    status)  cmd_status "$@" ;;
    logs)    cmd_logs "$@" ;;
    help|--help|-h)
        echo "Usage: feature-worktree.sh <command> [args]"
        echo ""
        echo "Commands:"
        echo "  create  <slot> <name> [--services svc1,svc2] [--<svc>-branch X ...]"
        echo "  start   <slot> [--services svc1,svc2] [--mode dev|docker]"
        echo "  stop    <slot>"
        echo "  destroy <slot> [--drop-schema]"
        echo "  status  [slot]"
        echo "  logs    <slot> [service]"
        echo ""
        echo "Slots: 1-${MAX_SLOTS}"
        ;;
    *) log_error "Unknown command: $cmd"; exit 1 ;;
esac
